# Copy this file to `.env` and fill in real values.

# MySQL connection string used by Prisma (CLI + runtime driver adapter).
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/grove"

# Auth.js secret used to sign session JWTs. Generate one with:
#   npx auth secret
# or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-me-with-a-strong-random-secret"

# Required when self-hosting (i.e. not on Vercel) so Auth.js trusts the host.
AUTH_TRUST_HOST=true
